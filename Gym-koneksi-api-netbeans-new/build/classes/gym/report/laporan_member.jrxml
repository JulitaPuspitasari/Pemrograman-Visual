<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_member" language="groovy" pageWidth="842" pageHeight="595"
              orientation="Landscape" columnWidth="802" columnSpacing="0"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="a0000001-0000-0000-0000-000000000001">

    <parameter name="judul" class="java.lang.String"/>
    <parameter name="subjudul" class="java.lang.String"/>
    <parameter name="tanggalCetak" class="java.lang.String"/>

    <field name="no" class="java.lang.Object"/>
    <field name="id_member" class="java.lang.String"/>
    <field name="nama" class="java.lang.String"/>
    <field name="jenis_kelamin" class="java.lang.String"/>
    <field name="tempat_lahir" class="java.lang.String"/>
    <field name="tanggal_lahir" class="java.lang.String"/>
    <field name="alamat" class="java.lang.String"/>
    <field name="no_hp" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="tanggal_daftar" class="java.lang.String"/>

    <title>
        <band height="80">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="55" backcolor="#E74C3C" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="8" width="802" height="25" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[GYM ME - FITNESS CENTER MANAGEMENT]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="32" width="802" height="18" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{judul}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="60" width="802" height="15" forecolor="#7F8C8D"/>
                <textElement textAlignment="Right">
                    <font fontName="SansSerif" size="9" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Tanggal Cetak: " + $P{tanggalCetak}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="30" backcolor="#2C3E50" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText><reportElement x="0"   y="0" width="30"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[No]]></text></staticText>
            <staticText><reportElement x="30"  y="0" width="70"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[ID Member]]></text></staticText>
            <staticText><reportElement x="100" y="0" width="120" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/><paragraph leftIndent="6"/></textElement><text><![CDATA[Nama]]></text></staticText>
            <staticText><reportElement x="220" y="0" width="60"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[JK]]></text></staticText>
            <staticText><reportElement x="280" y="0" width="80"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/><paragraph leftIndent="6"/></textElement><text><![CDATA[Tempat Lahir]]></text></staticText>
            <staticText><reportElement x="360" y="0" width="75"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Tgl Lahir]]></text></staticText>
            <staticText><reportElement x="435" y="0" width="130" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/><paragraph leftIndent="6"/></textElement><text><![CDATA[Alamat]]></text></staticText>
            <staticText><reportElement x="565" y="0" width="70"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[No HP]]></text></staticText>
            <staticText><reportElement x="635" y="0" width="100" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/><paragraph leftIndent="6"/></textElement><text><![CDATA[Email]]></text></staticText>
            <staticText><reportElement x="735" y="0" width="67"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Tgl Daftar]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField><reportElement x="0"   y="0" width="30"  height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{no}]]></textFieldExpression></textField>
            <textField><reportElement x="30"  y="0" width="70"  height="22"/><box leftPadding="4" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{id_member}]]></textFieldExpression></textField>
            <textField><reportElement x="100" y="0" width="120" height="22"/><box leftPadding="6" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{nama}]]></textFieldExpression></textField>
            <textField><reportElement x="220" y="0" width="60"  height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{jenis_kelamin}]]></textFieldExpression></textField>
            <textField><reportElement x="280" y="0" width="80"  height="22"/><box leftPadding="6" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{tempat_lahir}]]></textFieldExpression></textField>
            <textField><reportElement x="360" y="0" width="75"  height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{tanggal_lahir}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="435" y="0" width="130" height="22"/><box leftPadding="6" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{alamat}]]></textFieldExpression></textField>
            <textField><reportElement x="565" y="0" width="70"  height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{no_hp}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="635" y="0" width="100" height="22"/><box leftPadding="6" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{email}]]></textFieldExpression></textField>
            <textField><reportElement x="735" y="0" width="67"  height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{tanggal_daftar}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="25">
            <line><reportElement x="0" y="0" width="802" height="1" forecolor="#CCCCCC"/></line>
            <staticText>
                <reportElement x="0" y="6" width="400" height="15" forecolor="#7F8C8D"/>
                <textElement><font fontName="SansSerif" size="9" isItalic="true"/></textElement>
                <text><![CDATA[UAS Pemrograman Visual - Kelompok 2 - Universitas Indraprasta PGRI]]></text>
            </staticText>
            <textField evaluationTime="Now">
                <reportElement x="600" y="6" width="200" height="15" forecolor="#7F8C8D"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="9"/></textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="0" y="6" width="802" height="18"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Total Data: " + $V{REPORT_COUNT} + " member"]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
