<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="laporan_transaksi_membership" language="groovy" pageWidth="842" pageHeight="595"
              orientation="Landscape" columnWidth="802" columnSpacing="0"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="a0000001-0000-0000-0000-000000000003">

    <parameter name="judul" class="java.lang.String"/>
    <parameter name="tanggalCetak" class="java.lang.String"/>

    <field name="no" class="java.lang.Object"/>
    <field name="id_pendaftaran" class="java.lang.String"/>
    <field name="nama_member" class="java.lang.String"/>
    <field name="nama_paket" class="java.lang.String"/>
    <field name="tanggal_daftar" class="java.lang.String"/>
    <field name="tanggal_expired" class="java.lang.String"/>
    <field name="status" class="java.lang.String"/>

    <title>
        <band height="80">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="55" backcolor="#3498DB" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="8" width="802" height="25" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[GYM ME - FITNESS CENTER MANAGEMENT]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="32" width="802" height="18" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="SansSerif" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{judul}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="60" width="802" height="15" forecolor="#7F8C8D"/>
                <textElement textAlignment="Right">
                    <font fontName="SansSerif" size="9" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Tanggal Cetak: " + $P{tanggalCetak}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="30">
            <rectangle>
                <reportElement x="0" y="0" width="802" height="30" backcolor="#2C3E50" mode="Opaque"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText><reportElement x="0"   y="0" width="40"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[No]]></text></staticText>
            <staticText><reportElement x="40"  y="0" width="90"  height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[ID Pendaftaran]]></text></staticText>
            <staticText><reportElement x="130" y="0" width="180" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/><paragraph leftIndent="6"/></textElement><text><![CDATA[Nama Member]]></text></staticText>
            <staticText><reportElement x="310" y="0" width="150" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/><paragraph leftIndent="6"/></textElement><text><![CDATA[Paket Membership]]></text></staticText>
            <staticText><reportElement x="460" y="0" width="100" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Tgl Daftar]]></text></staticText>
            <staticText><reportElement x="560" y="0" width="100" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Tgl Expired]]></text></staticText>
            <staticText><reportElement x="660" y="0" width="142" height="30" forecolor="#FFFFFF"/><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Status]]></text></staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="22">
            <textField><reportElement x="0"   y="0" width="40"  height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{no}]]></textFieldExpression></textField>
            <textField><reportElement x="40"  y="0" width="90"  height="22"/><box leftPadding="4" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{id_pendaftaran}]]></textFieldExpression></textField>
            <textField><reportElement x="130" y="0" width="180" height="22"/><box leftPadding="6" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{nama_member}]]></textFieldExpression></textField>
            <textField><reportElement x="310" y="0" width="150" height="22"/><box leftPadding="6" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Left"   verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{nama_paket}]]></textFieldExpression></textField>
            <textField><reportElement x="460" y="0" width="100" height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{tanggal_daftar}]]></textFieldExpression></textField>
            <textField><reportElement x="560" y="0" width="100" height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9"/></textElement><textFieldExpression><![CDATA[$F{tanggal_expired}]]></textFieldExpression></textField>
            <textField><reportElement x="660" y="0" width="142" height="22"/><box leftPadding="2" rightPadding="2"><pen lineWidth="0.3" lineColor="#DDDDDD"/></box><textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><textFieldExpression><![CDATA[$F{status}]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="25">
            <line><reportElement x="0" y="0" width="802" height="1" forecolor="#CCCCCC"/></line>
            <staticText>
                <reportElement x="0" y="6" width="400" height="15" forecolor="#7F8C8D"/>
                <textElement><font fontName="SansSerif" size="9" isItalic="true"/></textElement>
                <text><![CDATA[UAS Pemrograman Visual - Kelompok 2 - Universitas Indraprasta PGRI]]></text>
            </staticText>
            <textField evaluationTime="Now">
                <reportElement x="600" y="6" width="200" height="15" forecolor="#7F8C8D"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="9"/></textElement>
                <textFieldExpression><![CDATA["Halaman " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <summary>
        <band height="30">
            <textField>
                <reportElement x="0" y="6" width="802" height="18"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["Total Transaksi: " + $V{REPORT_COUNT}]]></textFieldExpression>
